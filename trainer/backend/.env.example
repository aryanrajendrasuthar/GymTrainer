PORT=4000

# Allowed CORS origin — use http://localhost:3000 for local dev,
# your Vercel URL for production (e.g. https://trainer.vercel.app)
FRONTEND_URL=http://localhost:3000

# Supabase — copy from your project's Settings → API page
SUPABASE_URL=https://your-project-ref.supabase.co

# ⚠️  Service Role key — has full database access. NEVER commit the real value.
# Copy from Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
